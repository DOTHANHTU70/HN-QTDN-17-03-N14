<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_dang_ky_ca_tree" model="ir.ui.view">
        <field name="name">hr.dang.ky.ca.tree</field>
        <field name="model">hr_dang_ky_ca</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nhan_vien_id"/>
                <field name="dot_dang_ky_id"/>
                <field name="ngay_lam"/>
                <field name="ca_lam"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_dang_ky_ca_form" model="ir.ui.view">
        <field name="name">hr.dang.ky.ca.form</field>
        <field name="model">hr_dang_ky_ca</field>
        <field name="arch" type="xml">
            <form string="Đăng ký ca">
                <sheet>
                    <group>
                        <field name="nhan_vien_id"/>
                        <field name="dot_dang_ky_id"/>
                        <field name="ngay_lam"/>
                        <field name="ca_lam"/>
                        <field name="trang_thai"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_dang_ky_ca" model="ir.actions.act_window">
        <field name="name">Đăng ký ca</field>
        <field name="res_model">hr_dang_ky_ca</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>