<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_dot_dang_ky_tree" model="ir.ui.view">
        <field name="name">hr.dot.dang.ky.tree</field>
        <field name="model">hr_dot_dang_ky</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ten_dot"/>
                <field name="ngay_bat_dau"/>
                <field name="ngay_ket_thuc"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_dot_dang_ky_form" model="ir.ui.view">
        <field name="name">hr.dot.dang.ky.form</field>
        <field name="model">hr_dot_dang_ky</field>
        <field name="arch" type="xml">
            <form string="Đợt đăng ký">
                <sheet>
                    <group>
                        <field name="ten_dot"/>
                        <field name="ngay_bat_dau"/>
                        <field name="ngay_ket_thuc"/>
                        <field name="trang_thai"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_dot_dang_ky" model="ir.actions.act_window">
        <field name="name">Đợt đăng ký</field>
        <field name="res_model">hr_dot_dang_ky</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>