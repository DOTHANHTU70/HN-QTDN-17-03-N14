<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_phieu_luong_tree" model="ir.ui.view">
        <field name="name">hr.phieu.luong.tree</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nhan_vien_id"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="so_cong"/>
                <field name="luong_thuc_nhan"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_phieu_luong_form" model="ir.ui.view">
        <field name="name">hr.phieu.luong.form</field>
        <field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml">
            <form string="Phiếu lương">
                <sheet>
                    <group>
                        <field name="bang_luong_id"/>

                        <field name="nhan_vien_id" readonly="1"/>
                        <field name="thang" readonly="1"/>
                        <field name="nam" readonly="1"/>

                        <field name="so_cong" readonly="1"/>
                        <field name="tong_phu_cap" readonly="1"/>

                        <field name="thuong" readonly="1"/>
                        <field name="khau_tru" readonly="1"/>

                        <field name="tien_bhxh" readonly="1"/>
                        <field name="tien_bhyt" readonly="1"/>
                        <field name="tien_bhtn" readonly="1"/>

                        <field name="luong_thuc_nhan" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_phieu_luong" model="ir.actions.act_window">
        <field name="name">Phiếu lương</field>
        <field name="res_model">hr_phieu_luong</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>